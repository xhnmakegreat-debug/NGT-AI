# ==========================
# 1. 安全隐私 (绝对不能漏！)
# ==========================
.env
.env.local
*.key
*.pem
secrets.yaml
# 如果你的 config.yaml 里有密码，也要加上它，或者只上传 config.example.yaml

# ==========================
# 2. Python 垃圾文件
# ==========================
__pycache__/
*.pyc
*.pyo
*.pyd

# ==========================
# 3. 依赖库 (环境太大，不要传)
# ==========================
venv/
.venv/
env/
pip-wheel-metadata/

# ==========================
# 4. 前端垃圾 (如果你的 frontend 里有 node.js 项目)
# ==========================
node_modules/
dist/
build/
.npm
.eslintcache

# ==========================
# 5. 编辑器 & 系统生成文件
# ==========================
.vscode/
.idea/
.DS_Store
Thumbs.db

# ==========================
# 6. 项目运行时产生的临时文件
# ==========================
logs/
*.log
output/
tmp/
celerybeat-schedule
# ==========================
# 前端/Node.js 忽略规则 (React)
# ==========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
.env.local
.env.development.local
.env.test.local
.env.production.local